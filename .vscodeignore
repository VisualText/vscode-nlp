# Source files - bundled by webpack
src/**
tsconfig.json
webpack.config.js

# Standalone Cloudflare telemetry worker (deployed separately, never shipped)
telemetry-worker/**

# Formatter test-harness build output (npm run test:format) - never shipped
out-format/**

# Build artifacts we don't need
*.vsix
.vscode/**
# ...but ship the colorization template: colorizeAnalyzer() copies it into each workspace's .vscode/settings.json
!.vscode/settings.json
.claude/**

# Node modules - bundled by webpack
node_modules/**

# Development files
.git*
.eslintrc.json
npm-debug.log*
*.log
.nyc_output
coverage

# Test files
test/**
*.test.ts
*.test.js

# Keep only what's needed for the extension
!dist/extension.js
!dist/extension.js.map
!resources/**
!snippets/**
!syntaxes/**
!themes/**
!*.md
!*.html
!*-configuration.json
!.vscodeignore
!package.json
!LICENSE*