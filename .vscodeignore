# Source files - bundled by webpack
src/**
tsconfig.json
webpack.config.js

# Build artifacts we don't need  
*.vsix
.vscode/launch.json
.vscode/tasks.json

# Node modules - bundled by webpack
node_modules/**

# Development files
.git*
.eslintrc.json
npm-debug.log*
.nyc_output
coverage

# Test files
test/**
*.test.ts
*.test.js

# Keep only what's needed for the extension
!dist/extension.js
!dist/extension.js.map
!resources/**
!snippets/**
!syntaxes/**
!themes/**
!*.md
!*.html
!*-configuration.json
!.vscodeignore
!package.json
!LICENSE*